{
    "name": "dvrtech/laravel-chartjs",
    "description": "Render Chart.js charts to images in PHP/Laravel via a bundled Windows executable, ready to embed in PDFs.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "chartjs", "chart", "pdf", "image", "dompdf", "mpdf", "tcpdf"],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "symfony/process": "^6.0 || ^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dvrtech\\LaravelChartJs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dvrtech\\LaravelChartJs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dvrtech\\LaravelChartJs\\ChartJsServiceProvider"
            ],
            "aliases": {
                "ChartJs": "Dvrtech\\LaravelChartJs\\Facades\\ChartJs"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
